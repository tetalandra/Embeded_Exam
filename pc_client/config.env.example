# Copy this file to config.env and edit the values.

# Serial communication (Arduino <-> PC)
SERIAL_PORT=COM3
BAUD_RATE=9600

# MQTT broker on VPS
MQTT_BROKER=your.vps.hostname.or.ip
MQTT_PORT=1883
MQTT_TOPIC=embedded/exam/temperature

# Optional MQTT authentication
MQTT_USERNAME=
MQTT_PASSWORD=

# Shown in console output and included in MQTT payload
CANDIDATE_NAME=Your Full Candidate Name Here

# Local web dashboard (open http://localhost:8080)
DASHBOARD_PORT=8080
ENABLE_DASHBOARD=true
